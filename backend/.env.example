# ===========================================
# China AI Import Assistant - Configuration
# Copiez ce fichier en .env et remplissez les valeurs
# ===========================================

# --- Application ---
APP_NAME=China AI Import Assistant
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1

# --- Sécurité / JWT ---
# Générez une clé forte avec : openssl rand -hex 32
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND_HEX_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Base de données PostgreSQL ---
DATABASE_URL=postgresql+psycopg2://china_ai_user:china_ai_password@localhost:5432/china_ai_db
DATABASE_ECHO=False

# --- CORS (origines autorisées, séparées par des virgules dans le JSON) ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# --- IA : Mistral ---
# Obtenez votre clé sur https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-large-latest
MISTRAL_API_URL=https://api.mistral.ai/v1/chat/completions
MISTRAL_TIMEOUT_SECONDS=60
# API OCR dédiée (réutilise MISTRAL_API_KEY) : repli automatique quand Tesseract
# n'est pas disponible localement (ex. environnement serverless comme Vercel).
MISTRAL_OCR_API_URL=https://api.mistral.ai/v1/ocr
MISTRAL_OCR_MODEL=mistral-ocr-latest

# --- OCR ---
OCR_LANG=chi_sim+eng+fra
TESSERACT_CMD=/usr/bin/tesseract

# --- Scraper ---
SCRAPER_HEADLESS=True
SCRAPER_TIMEOUT_MS=30000
SCRAPER_MAX_RETRIES=3
# SCRAPER_PROXY=http://user:pass@proxy-host:port

# --- Uploads ---
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Estimation import (tarifs indicatifs, non temps réel) ---
IMPORT_AIR_RATE_CNY_PER_KG=55.0
IMPORT_SEA_RATE_CNY_PER_KG=12.0
IMPORT_EUR_CNY_RATE=0.13
